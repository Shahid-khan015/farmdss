import React from 'react';
import { ScrollView, View, StyleSheet, Pressable } from 'react-native';
import { Text } from 'react-native-paper';
import { useNavigation, useRoute } from '@react-navigation/native';
import { Feather } from '@expo/vector-icons';

import { colors } from '../constants/colors';
import { spacing, typography, borderRadius } from '../theme';
import { LoadingSpinner } from '../components/common/LoadingSpinner';
import { ErrorMessage } from '../components/common/ErrorMessage';
import { Card } from '../components/common/Card';
import { Button } from '../components/common/Button';
import { CollapsibleSection } from '../components/common/CollapsibleSection';
import { ResultsDisplay } from '../components/simulation/ResultsDisplay';
import { RecommendationCard } from '../components/simulation/RecommendationCard';
import { useSimulation } from '../hooks/useSimulations';
import { fmtNum } from '../utils/formatters';

export function SimulationResultScreen() {
  const nav = useNavigation<any>();
  const route = useRoute<any>();
  const id = route.params?.id as string;

  const simQ = useSimulation(id);

  if (simQ.isLoading) return <LoadingSpinner />;
  if (simQ.error) return <ErrorMessage message={(simQ.error as Error).message} />;
  if (!simQ.data) return <ErrorMessage message="Simulation not found." />;

  const s = simQ.data;
  // Merge top-level persisted columns with results JSON in case either side is partial.
  const r = { ...s, ...(s.results ?? {}) };

  return (
    <ScrollView contentContainerStyle={styles.scrollContainer} showsVerticalScrollIndicator={false}>
      {/* Header */}
      <View style={styles.header}>
        <Pressable onPress={() => nav.goBack()} style={styles.backButton}>
          <Feather name="arrow-left" size={24} color={colors.primary} />
        </Pressable>
        <View style={styles.headerContent}>
          <Text style={styles.headerTitle}>{s.name ?? 'Simulation Result'}</Text>
          <Text style={styles.headerSubtitle}>
            {new Date(s.created_at).toLocaleDateString()} • {new Date(s.created_at).toLocaleTimeString()}
          </Text>
        </View>
      </View>

      {/* Key Metrics Summary */}
      <View style={styles.metricsGrid}>
        <Card variant="elevated" style={styles.metricCard}>
          <View style={styles.metricCardContent}>
            <Feather name="trending-up" size={20} color={colors.primary} />
            <Text style={styles.metricLabel}>Slip</Text>
            <Text style={styles.metricValueLarge}>
              {fmtNum((r as any).slip ?? s.slip, 2)}%
            </Text>
          </View>
        </Card>
        <Card variant="elevated" style={styles.metricCard}>
          <View style={styles.metricCardContent}>
            <Feather name="zap" size={20} color={colors.secondary} />
            <Text style={styles.metricLabel}>Efficiency</Text>
            <Text style={styles.metricValueLarge}>
              {fmtNum((r as any).overall_efficiency ?? s.overall_efficiency, 2)}%
            </Text>
          </View>
        </Card>
      </View>

      {/* Operating Conditions */}
      <CollapsibleSection title="Operating Conditions" icon="settings" defaultExpanded>
        <View style={styles.detailsGrid}>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Depth</Text>
            <Text style={styles.detailValue}>{fmtNum(s.depth as number | null | undefined, 2)} cm</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Speed</Text>
            <Text style={styles.detailValue}>{fmtNum(s.speed as number | null | undefined, 2)} km/h</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Cone Index</Text>
            <Text style={styles.detailValue}>{fmtNum(s.cone_index as number | null | undefined, 2)} kPa</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Field Area</Text>
            <Text style={styles.detailValue}>{fmtNum(s.field_area as number | null | undefined, 2)} ha</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Field Length</Text>
            <Text style={styles.detailValue}>{fmtNum(s.field_length as number | null | undefined, 2)} m</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Field Width</Text>
            <Text style={styles.detailValue}>{fmtNum(s.field_width as number | null | undefined, 2)} m</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Number of Turns</Text>
            <Text style={styles.detailValue}>{s.number_of_turns ?? '-'}</Text>
          </View>
          <View style={styles.detailItem}>
            <Text style={styles.detailLabel}>Soil Type</Text>
            <Text style={styles.detailValue}>
              {s.soil_texture ?? '-'} / {s.soil_hardness ?? '-'}
            </Text>
          </View>
        </View>
      </CollapsibleSection>

      {/* Results Display */}
      <CollapsibleSection title="Detailed Results" icon="activity" defaultExpanded={false}>
        <ResultsDisplay results={r} />
      </CollapsibleSection>

      {/* Recommendations */}
      <View style={styles.recommendationsSection}>
        <RecommendationCard
          statusMessage={s.status_message ?? (r as any).status_message}
          recommendations={s.recommendations ?? (r as any).recommendations}
          slip={Number((r as any).slip ?? s.slip ?? null)}
          loadStatus={(r as any).load_status ?? null}
        />
      </View>

      {/* Action Buttons */}
      <View style={styles.footer}>
        <Button
          variant="primary"
          size="lg"
          fullWidth
          onPress={() => nav.navigate('SimulationSetup')}
        >
          Run New Simulation
        </Button>
        <Button
          variant="secondary"
          size="lg"
          fullWidth
          onPress={() => nav.navigate('SimulationHistory')}
        >
          View All Simulations
        </Button>
        <Button
          variant="outline"
          size="lg"
          fullWidth
          onPress={() => nav.goBack()}
        >
          Back
        </Button>
      </View>
    </ScrollView>
  );
}

const styles = StyleSheet.create({
  scrollContainer: {
    paddingHorizontal: spacing.lg,
    paddingTop: spacing.lg,
    paddingBottom: spacing.xxl,
    backgroundColor: colors.background,
  },
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    marginBottom: spacing.xxl,
    gap: spacing.md,
  },
  backButton: {
    width: 44,
    height: 44,
    borderRadius: borderRadius.md,
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: '#F3F4F6',
  },
  headerContent: {
    flex: 1,
  },
  headerTitle: {
    ...typography.h3,
    color: colors.text,
  },
  headerSubtitle: {
    ...typography.bodySmall,
    color: colors.muted,
    marginTop: spacing.xs,
  },
  metricsGrid: {
    flexDirection: 'row',
    gap: spacing.md,
    marginBottom: spacing.lg,
  },
  metricCard: {
    flex: 1,
    marginBottom: 0,
  },
  metricCardContent: {
    alignItems: 'center',
    gap: spacing.sm,
  },
  metricLabel: {
    ...typography.bodySmall,
    color: colors.muted,
  },
  metricValueLarge: {
    ...typography.h4,
    color: colors.primary,
    marginTop: spacing.xs,
  },
  detailsGrid: {
    display: 'flex',
    flexDirection: 'row',
    flexWrap: 'wrap',
    gap: spacing.md,
  },
  detailItem: {
    width: '48%',
    paddingHorizontal: spacing.md,
    paddingVertical: spacing.sm,
    borderRadius: borderRadius.md,
    backgroundColor: '#F9FAFB',
  },
  detailLabel: {
    ...typography.labelSmall,
    color: colors.muted,
  },
  detailValue: {
    ...typography.label,
    color: colors.text,
    marginTop: spacing.xs / 2,
  },
  recommendationsSection: {
    marginTop: spacing.lg,
    marginBottom: spacing.lg,
  },
  footer: {
    gap: spacing.md,
    marginTop: spacing.xl,
  },
});
